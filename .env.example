# Supabase — prediction league backend.
# Copy to .env.local and fill in from your Supabase project (Settings → API).
# Use the ANON public key only. Never put the service-role key in the browser.
#
# The Watch app (Today/Recent/verdict) works WITHOUT these set — only the
# league features require them.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Live results: ESPN's free JSON overlays fresher scores/goals on top of the
# openfootball fixtures backbone (on by default). If ESPN breaks mid-tournament,
# set this to 1 and redeploy to fall back to openfootball-only.
VITE_DISABLE_ESPN=
